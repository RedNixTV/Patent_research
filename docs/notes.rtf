export async function deleteProject(\
    projectId\
) \{\
\
    const projects =\
        await getProjects();\
\
    const filtered =\
        projects.filter(\
            project =>\
                project.id !==\
                projectId\
        );\
\
    if (\
        filtered.length === 0\
    ) \{\
\
        filtered.push(\{\
\
            id: "default",\
            name: "Default Project",\
\
            landscapeScan: []\
        \});\
    \}\
\
    await chrome.storage.local.set(\{\
\
        projects: filtered,\
\
        currentProjectId:\
            filtered[0].id\
    \});\
\}\
\
