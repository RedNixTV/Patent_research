export async function createProject(\
    name\
) \{\
\
    const projects =\
        await getProjects();\
\
    const id =\
        crypto.randomUUID();\
\
    projects.push(\{\
\
        id,\
        name,\
\
        landscapeScan: []\
    \});\
\
    await chrome.storage.local.set(\{\
\
        projects,\
        currentProjectId: id\
    \});\
\
    return id;\
\}\
\
